rows = 5

for i in range(1, rows + 1):
    # Calculate and print leading spaces for centering
    leading_spaces = rows - i
    print(" " * leading_spaces, end="")

    # Print stars with a space between them (but no trailing space after the last star)
    for j in range(i):
        print("*", end="")
        if j < i - 1: # Don't print a space after the last star in the row
            print(" ", end="")
    print()
